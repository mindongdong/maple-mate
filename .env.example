# maple-mate 환경변수 — 키 이름만 (값 없음). 실제 값은 .env 에 채우고 절대 커밋 금지.
# fail-fast: 아래 필수 키가 비어 있으면 기동 거부.

# Discord 봇 토큰
DISCORD_BOT_TOKEN=

# 넥슨 Open API 앱 키 (스펙류·알림)
NEXON_APP_KEY=

# 개인 키 암호화 마스터 키 (cryptography Fernet.generate_key() 값)
FERNET_MASTER_KEY=

# 수동 썬데이 HTTP 엔드포인트 Bearer 토큰 (Phase 4, 로딩은 지금부터)
OPERATOR_TOKEN=

# 운영 요약 채널 ID (Discord 채널 snowflake)
ADMIN_CHANNEL_ID=

# Postgres (asyncpg) DSN
DATABASE_URL=postgresql+asyncpg://maple:maple@localhost:5433/maple_mate

# (선택) 개발용 길드 스코프 즉시 등록 (Discord 길드 snowflake).
# 비우면 운영 글로벌 동기화(반영까지 최대 1시간), 값 지정 시 그 길드에 즉시 등록.
DEV_GUILD_ID=
